#!/bin/bash
#
# Git commit-msg hook to enforce commit message conventions
#
# Format: <emoji> <type>[(<scope>)][!]: <description>
#
# Valid types & emojis:
#   ✨ feat: New features
#   🐛 fix: Bug fixes
#   📚 docs: Documentation
#   💄 style: Formatting
#   ♻️ refactor: Restructuring
#   ⚡ perf: Performance
#   🧪 test: Testing
#   🔧 build: Build changes
#   🧹 chore: Maintenance
#   📋 plan: Planning updates
#   🔒 security: Security fixes
#   🗃️ migration: Database migrations
#   📦 deps: Dependency updates
#   🚀 deploy: Deployment/CI changes
#   🔥 remove: Removing code/features
#   🩹 hotfix: Urgent fixes
#   🔀 merge: Branch merges
#   🔄 ci: CI/CD config
#   ↩️ revert: Revert a previous commit
#
# Rules:
#   - NO AI signatures (Co-Authored-By: Claude, etc.)
#   - Present tense, lowercase description
#   - Atomic commits
#

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

#
# 1. Check for AI co-author signatures
#
AI_PATTERNS=(
    # Catch-all: any Co-Authored-By with a noreply@ email (all AI providers use this)
    "Co-[Aa]uthored-[Bb]y:.*noreply@"
    # Catch-all: any Co-Authored-By from known AI provider domains
    "Co-[Aa]uthored-[Bb]y:.*@anthropic\.com"
    "Co-[Aa]uthored-[Bb]y:.*@openai\.com"
    "Co-[Aa]uthored-[Bb]y:.*@github\.com.*[Bb]ot"
    "Co-[Aa]uthored-[Bb]y:.*@google\.com.*[Aa][Ii]"
    # Specific AI/assistant names used as co-authors
    "Co-[Aa]uthored-[Bb]y:.*[Cc]laude"
    "Co-[Aa]uthored-[Bb]y:.*[Cc]opilot"
    "Co-[Aa]uthored-[Bb]y:.*[Gg]emini"
    "Co-[Aa]uthored-[Bb]y:.*[Gg][Pp][Tt]"
    "Co-[Aa]uthored-[Bb]y:.*[Cc]hat[Gg][Pp][Tt]"
    "Co-[Aa]uthored-[Bb]y:.*[Cc]odeium"
    "Co-[Aa]uthored-[Bb]y:.*[Tt]abby"
    "Co-[Aa]uthored-[Bb]y:.*[Cc]ursor"
    # Agent names from the team system
    "Co-[Aa]uthored-[Bb]y:.*[Ss]pider-[Mm]an"
    "Co-[Aa]uthored-[Bb]y:.*[Ii]ron [Mm]an"
    "Co-[Aa]uthored-[Bb]y:.*[Tt]hor"
    "Co-[Aa]uthored-[Bb]y:.*[Hh]ulk"
    "Co-[Aa]uthored-[Bb]y:.*[Nn]ick [Ff]ury"
    "Co-[Aa]uthored-[Bb]y:.*[Hh]awkeye"
    "Co-[Aa]uthored-[Bb]y:.*[Jj][Aa][Rr][Vv][Ii][Ss]"
    # "Generated by" signatures
    "Generated by AI"
    "Generated by Claude"
    "Generated by GPT"
    "Generated by Copilot"
    "Generated with Claude"
    "Generated with \[Claude"
)

for pattern in "${AI_PATTERNS[@]}"; do
    if echo "$COMMIT_MSG" | grep -qiE "$pattern"; then
        MATCHED_LINE=$(echo "$COMMIT_MSG" | grep -iE "$pattern" | head -n 1)
        echo ""
        echo -e "${RED}ERROR: Commit rejected — AI signature detected!${NC}"
        echo ""
        echo -e "  Matched line: ${YELLOW}${MATCHED_LINE}${NC}"
        echo ""
        echo "No AI co-author or attribution allowed. Remove the line and try again."
        echo ""
        exit 1
    fi
done

#
# 2. Validate commit message format
#
# Valid emoji + type combinations (supports optional scope and breaking change marker)
# Format: <emoji> <type>[(<scope>)][!]: <description>
VALID_PATTERNS=(
    "^✨ feat(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🐛 fix(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^📚 docs(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^💄 style(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^♻️ refactor(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^⚡ perf(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🧪 test(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🔧 build(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🧹 chore(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^📋 plan(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🔒 security(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🗃️ migration(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^📦 deps(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🚀 deploy(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🔥 remove(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🩹 hotfix(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🔀 merge(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^🔄 ci(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
    "^↩️ revert(\([a-zA-Z0-9/_-]+\))?(!)?: .+"
)

# Check if first line matches any valid pattern
VALID_FORMAT=false
for pattern in "${VALID_PATTERNS[@]}"; do
    if echo "$FIRST_LINE" | grep -qE "$pattern"; then
        VALID_FORMAT=true
        break
    fi
done

if [ "$VALID_FORMAT" = false ]; then
    echo ""
    echo -e "${RED}ERROR: Invalid commit message format!${NC}"
    echo ""
    echo "Your message: $FIRST_LINE"
    echo ""
    echo -e "${YELLOW}Required format:${NC} <emoji> <type>[(<scope>)][!]: <description>"
    echo ""
    echo "Valid types & emojis:"
    echo "  ✨ feat:     New features"
    echo "  🐛 fix:      Bug fixes"
    echo "  📚 docs:     Documentation"
    echo "  💄 style:    Formatting"
    echo "  ♻️ refactor: Restructuring"
    echo "  ⚡ perf:     Performance"
    echo "  🧪 test:     Testing"
    echo "  🔧 build:    Build changes"
    echo "  🧹 chore:    Maintenance"
    echo "  📋 plan:     Planning updates"
    echo "  🔒 security: Security fixes"
    echo "  🗃️ migration: Database migrations"
    echo "  📦 deps:     Dependency updates"
    echo "  🚀 deploy:   Deployment/CI changes"
    echo "  🔥 remove:   Removing code/features"
    echo "  🩹 hotfix:   Urgent fixes"
    echo "  🔀 merge:    Branch merges"
    echo "  🔄 ci:       CI/CD config"
    echo "  ↩️ revert:   Revert a previous commit"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ✨ feat: add user authentication"
    echo "  ✨ feat(installer): add gum menu"
    echo "  💥 feat!: rename workspace"
    echo "  🔄 ci: add release workflow"
    echo ""
    exit 1
fi

#
# 3. Check for description after the colon
#
DESCRIPTION=$(echo "$FIRST_LINE" | sed -E 's/^.* (feat|fix|docs|style|refactor|perf|test|build|chore|plan|security|migration|deps|deploy|remove|hotfix|merge|ci|revert)(\([a-zA-Z0-9/_-]+\))?(!)?: *//')

if [ -z "$DESCRIPTION" ]; then
    echo ""
    echo -e "${RED}ERROR: Missing description after type!${NC}"
    echo ""
    echo "Your message: $FIRST_LINE"
    echo ""
    echo -e "${GREEN}Example:${NC} ✨ feat(auth): add user authentication"
    echo ""
    exit 1
fi

#
# 4. Check that description starts with lowercase (warning only)
#
FIRST_CHAR=$(echo "$DESCRIPTION" | cut -c1)
if [[ "$FIRST_CHAR" =~ [A-Z] ]]; then
    echo ""
    echo -e "${YELLOW}WARNING: Description should start with lowercase${NC}"
    echo ""
    echo "Your message: $FIRST_LINE"
    echo ""
    echo "This is a style warning - commit will proceed."
    echo ""
fi

# All checks passed
exit 0
